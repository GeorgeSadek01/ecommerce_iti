# MongoDB
MONGO_URI=mongodb://localhost:27017/SoldierStore

# App
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Auth / tokens
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend
FRONTEND_URL=http://localhost:3000

# OAuth / Social
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_KEY=

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM_EMAIL=no-reply@example.com

# AWS / S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Monitoring / errors
SENTRY_DSN=

CLIENT_URL_SUCCESS_PAYMENT=http://localhost:3000/success.html
CLIENT_URL_FAILURE_PAYMENT=http://localhost:3000/failure.html

# Notes:
# - Replace placeholders with real secrets in production.
# - Keep this file out of version control; commit only this example file.
