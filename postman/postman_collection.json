{
  "info": {
    "name": "Ecommerce API",
    "_postman_id": "ecommerce-api-collection-v1",
    "description": "Complete API collection for the Ecommerce backend. Base URL: {{base_url}} (default: http://localhost:4000)\n\n**Auth flow:**\n1. POST /api/v1/auth/register\n2. GET  /api/v1/auth/confirm/:token  (token arrives by email)\n3. POST /api/v1/auth/login  → saves accessToken + refreshToken cookie\n4. Use `Authorization: Bearer {{token}}` on protected routes\n5. POST /api/v1/auth/refresh  → rotates tokens\n6. POST /api/v1/auth/logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns `{ status: 'ok' }` when the server is running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Body has status ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "Auth",
      "description": "Registration, email confirmation, login, token refresh and logout.",
      "item": [

        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Create a new user account. A confirmation email is sent to the provided address.\n\n**Password rules:** min 8 chars, at least 1 uppercase letter, at least 1 number."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Response has user object', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.user).to.be.an('object');",
                  "  pm.expect(json.data.user.email).to.exist;",
                  "  pm.expect(json.data.user).to.not.have.property('passwordHash');",
                  "});",
                  "// Store userId for later requests",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.user && json.data.user.id) {",
                  "  pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },

        {
          "name": "Confirm Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/confirm/{{confirmToken}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "confirm", "{{confirmToken}}"]
            },
            "description": "Confirm a user's email using the JWT token delivered by email.\n\nSet `confirmToken` collection variable to the token value from the link."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Body has success status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate and obtain tokens.\n\n- **Response body:** `accessToken` (15 min JWT)\n- **Cookie:** `refreshToken` HTTP-only cookie (7 days)\n\nThe test script automatically saves `accessToken` to the `token` collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Response has accessToken', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.to.have.length.above(0);",
                  "});",
                  "pm.test('Response has user object', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.user).to.be.an('object');",
                  "  pm.expect(json.data.user.role).to.exist;",
                  "});",
                  "// Auto-save token for subsequent requests",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "  console.log('Access token saved to collection variable: token');",
                  "}"
                ]
              }
            }
          ]
        },

        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Rotate the refresh token and get a new access token.\n\nRequires `refreshToken` HTTP-only cookie (set automatically by Login).\nReturns a new `accessToken` and rotates the cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('New accessToken is returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.to.have.length.above(0);",
                  "});",
                  "// Update saved token",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Revoke the refresh token and clear the cookie.\n\nRequires `refreshToken` HTTP-only cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Logout message present', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "// Clear token from collection",
                  "pm.collectionVariables.set('token', '');"
                ]
              }
            }
          ]
        }

      ]
    },

