{
  "name": "backend",
  "version": "1.0.0",
  "description": "MEAN E-Commerce Platform - Backend API",
  "type": "module",
  "main": "apps/backend/src/server.js",
  "scripts": {
    "dev": "npx nodemon apps/backend/src/server.js",
    "start": "node apps/backend/src/server.js",
    "start:prod": "NODE_ENV=production node apps/backend/src/server.js",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:api": "newman run endpoints/ecommerce.postman.json -e endpoints/ecommerce.local.postman_environment.json --reporters cli",
    "test:api:ci": "newman run endpoints/ecommerce.postman.json -e endpoints/ecommerce.local.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-junit.xml"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "newman": "^6.2.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.14",
    "slugify": "^1.6.6",
    "stripe": "^20.4.1"
  }
}
